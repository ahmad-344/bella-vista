# ================================================
# BELLA VISTA — Environment Variables
# ================================================
# 1. Supabase dashboard par jao: https://supabase.com
# 2. New project banao "bella-vista"
# 3. Settings > API se ye values copy karo
# 4. Is file ko copy kar ke ".env" naam do
# 5. Apni values bharo

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin email — yehi email admin login k liye use hogi
VITE_ADMIN_EMAIL=admin@bellavista.pk
